@using PackTrack.Models.Dtos

<MudPaper Class="pa-6 glass-panel" Elevation="0">
    <div class="d-flex align-center gap-2 mb-4">
        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Warning" />
        <MudText Typo="Typo.h6" Style="font-weight: 700;">Driver Performance</MudText>
    </div>

    @if (Drivers.Any())
    {
        <MudGrid Spacing="3">
            @foreach (var driver in Drivers)
            {
                <MudItem xs="12" sm="6" md="4">
                    <div class="driver-card pa-4 rounded-lg">
                        <div class="d-flex align-center gap-3 mb-3">
                            <MudAvatar Color="@GetRankColor(driver)" Size="Size.Medium" Style="font-weight: 800;">
                                @driver.DriverId[..2].ToUpper()
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.body1" Style="font-weight: 700;">@driver.DriverId</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@driver.TotalTrips trips total</MudText>
                            </div>
                        </div>

                        <div class="d-flex justify-space-between mb-2">
                            <div>
                                <MudText Typo="Typo.caption" Class="stat-label">On-Time Rate</MudText>
                                <MudText Typo="Typo.h6" Style="@($"font-weight: 800; color: {GetOnTimeColor(driver.OnTimePercent)};")">
                                    @driver.OnTimePercent%
                                </MudText>
                            </div>
                            <div class="text-right">
                                <MudText Typo="Typo.caption" Class="stat-label">Avg Trip</MudText>
                                <MudText Typo="Typo.h6" Style="font-weight: 800;">
                                    @(driver.AvgTripHours > 0 ? $"{driver.AvgTripHours}h" : "—")
                                </MudText>
                            </div>
                        </div>

                        <MudProgressLinear Color="@(driver.OnTimePercent >= 90 ? Color.Success : driver.OnTimePercent >= 70 ? Color.Warning : Color.Error)"
                                           Value="@driver.OnTimePercent" Size="Size.Small" Rounded="true" />
                        
                        <div class="d-flex justify-space-between mt-2">
                            <MudText Typo="Typo.caption" Color="Color.Success">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" /> @driver.OnTimeDeliveries on-time
                            </MudText>
                            @if (driver.TotalTrips - driver.OnTimeDeliveries > 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error">
                                    @(driver.TotalTrips - driver.OnTimeDeliveries) delayed
                                </MudText>
                            }
                        </div>
                    </div>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            No driver data available. Assign drivers to shipments to see performance metrics.
        </MudAlert>
    }
</MudPaper>

<style>
    .driver-card {
        background: rgba(255, 255, 255, 0.5);
        border: 1px solid rgba(0, 0, 0, 0.06);
        transition: all 0.25s ease;
    }
    .driver-card:hover {
        background: rgba(255, 255, 255, 0.9);
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    }
    .stat-label {
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }
</style>

@code {
    [Parameter] public List<DriverStats> Drivers { get; set; } = new();

    private Color GetRankColor(DriverStats d)
    {
        if (d.OnTimePercent >= 95) return Color.Success;
        if (d.OnTimePercent >= 80) return Color.Warning;
        return Color.Error;
    }

    private string GetOnTimeColor(double percent)
    {
        if (percent >= 90) return "#00c853";
        if (percent >= 70) return "#ff9100";
        return "#ff5252";
    }
}
